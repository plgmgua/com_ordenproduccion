<?xml version="1.0" encoding="utf-8"?>
<extension type="module" client="site" method="upgrade">
    <name>MOD_ORDOP_PENDING_APPROVALS</name>
    <author>Grimpsa Development Team</author>
    <creationDate>2026-04-16</creationDate>
    <copyright>Copyright (C) 2026 Grimpsa. All rights reserved.</copyright>
    <license>GNU General Public License version 2 or later</license>
    <authorEmail>admin@grimpsa.com</authorEmail>
    <authorUrl>https://grimpsa.com</authorUrl>
    <version>1.1.1-STABLE</version>
    <description>MOD_ORDOP_PENDING_APPROVALS_XML_DESCRIPTION</description>

    <files>
        <filename module="mod_ordop_pending_approvals">mod_ordop_pending_approvals.php</filename>
        <folder>helper</folder>
        <folder>tmpl</folder>
        <folder>language</folder>
    </files>

    <languages folder="language">
        <language tag="en-GB">en-GB/mod_ordop_pending_approvals.ini</language>
        <language tag="en-GB">en-GB/mod_ordop_pending_approvals.sys.ini</language>
        <language tag="es-ES">es-ES/mod_ordop_pending_approvals.ini</language>
        <language tag="es-ES">es-ES/mod_ordop_pending_approvals.sys.ini</language>
    </languages>

    <config>
        <fields name="params">
            <fieldset name="basic" label="MOD_ORDOP_PENDING_APPROVALS_CONFIG_BASIC_LABEL">
                <field
                    name="show_full_link"
                    type="radio"
                    label="MOD_ORDOP_PENDING_APPROVALS_SHOW_FULL_LINK_LABEL"
                    description="MOD_ORDOP_PENDING_APPROVALS_SHOW_FULL_LINK_DESC"
                    default="1"
                    class="btn-group btn-group-yesno"
                >
                    <option value="1">JYES</option>
                    <option value="0">JNO</option>
                </field>
                <field
                    name="hide_when_empty"
                    type="radio"
                    label="MOD_ORDOP_PENDING_APPROVALS_HIDE_EMPTY_LABEL"
                    description="MOD_ORDOP_PENDING_APPROVALS_HIDE_EMPTY_DESC"
                    default="0"
                    class="btn-group btn-group-yesno"
                >
                    <option value="1">JYES</option>
                    <option value="0">JNO</option>
                </field>
            </fieldset>
            <fieldset name="advanced">
                <field
                    name="layout"
                    type="modulelayout"
                    label="JFIELD_ALT_LAYOUT_LABEL"
                    class="form-select"
                    validate="moduleLayout"
                />
                <field
                    name="moduleclass_sfx"
                    type="textarea"
                    label="COM_MODULES_FIELD_MODULECLASS_SFX_LABEL"
                    rows="3"
                />
            </fieldset>
        </fields>
    </config>
</extension>
