<?xml version="1.0" encoding="utf-8"?>
<config>
    <fieldset name="component" label="COM_ORDENPRODUCCION_CONFIGURATION">
        <field
            name="show_title"
            type="radio"
            label="COM_ORDENPRODUCCION_SHOW_TITLE_LABEL"
            description="COM_ORDENPRODUCCION_SHOW_TITLE_DESC"
            default="1"
            class="btn-group btn-group-yesno"
        >
            <option value="0">JNO</option>
            <option value="1">JYES</option>
        </field>
        <field
            name="items_per_page"
            type="number"
            label="COM_ORDENPRODUCCION_ITEMS_PER_PAGE_LABEL"
            description="COM_ORDENPRODUCCION_ITEMS_PER_PAGE_DESC"
            default="20"
            min="5"
            max="100"
        />
        <field
            name="default_order_status"
            type="list"
            label="COM_ORDENPRODUCCION_DEFAULT_ORDER_STATUS_LABEL"
            description="COM_ORDENPRODUCCION_DEFAULT_ORDER_STATUS_DESC"
            default="nueva"
        >
            <option value="nueva">COM_ORDENPRODUCCION_STATUS_NUEVA</option>
            <option value="en_proceso">COM_ORDENPRODUCCION_STATUS_EN_PROCESO</option>
            <option value="terminada">COM_ORDENPRODUCCION_STATUS_TERMINADA</option>
            <option value="cerrada">COM_ORDENPRODUCCION_STATUS_CERRADA</option>
        </field>
        <field
            name="auto_assign_technicians"
            type="radio"
            label="COM_ORDENPRODUCCION_AUTO_ASSIGN_TECHNICIANS_LABEL"
            description="COM_ORDENPRODUCCION_AUTO_ASSIGN_TECHNICIANS_DESC"
            default="1"
            class="btn-group btn-group-yesno"
        >
            <option value="0">JNO</option>
            <option value="1">JYES</option>
        </field>
        <field
            name="enable_calendar_view"
            type="radio"
            label="COM_ORDENPRODUCCION_ENABLE_CALENDAR_VIEW_LABEL"
            description="COM_ORDENPRODUCCION_ENABLE_CALENDAR_VIEW_DESC"
            default="1"
            class="btn-group btn-group-yesno"
        >
            <option value="0">JNO</option>
            <option value="1">JYES</option>
        </field>
    </fieldset>
    <fieldset name="integraciones" label="COM_ORDENPRODUCCION_CONFIG_INTEGRACIONES_LABEL">
        <field
            name="anulacion_url"
            type="url"
            label="COM_ORDENPRODUCCION_CONFIG_ANULACION_URL_LABEL"
            description="COM_ORDENPRODUCCION_CONFIG_ANULACION_URL_DESC"
            default="https://grimpsa_webserver.grantsolutions.cc/index.php/anulacion-de-orden"
            size="80"
            filter="url"
        />
    </fieldset>
    <fieldset name="telegram" label="COM_ORDENPRODUCCION_CONFIG_TELEGRAM_FIELDSET_LABEL">
        <field
            name="telegram_enabled"
            type="radio"
            label="COM_ORDENPRODUCCION_CONFIG_TELEGRAM_ENABLED_LABEL"
            description="COM_ORDENPRODUCCION_CONFIG_TELEGRAM_ENABLED_DESC"
            default="0"
            class="btn-group btn-group-yesno"
        >
            <option value="1">JYES</option>
            <option value="0">JNO</option>
        </field>
        <field
            name="telegram_bot_token"
            type="password"
            label="COM_ORDENPRODUCCION_CONFIG_TELEGRAM_BOT_TOKEN_LABEL"
            description="COM_ORDENPRODUCCION_CONFIG_TELEGRAM_BOT_TOKEN_DESC"
            default=""
            size="60"
            filter="string"
        />
        <field
            name="telegram_notify_invoice"
            type="radio"
            label="COM_ORDENPRODUCCION_CONFIG_TELEGRAM_NOTIFY_INVOICE_LABEL"
            description="COM_ORDENPRODUCCION_CONFIG_TELEGRAM_NOTIFY_INVOICE_DESC"
            default="0"
            class="btn-group btn-group-yesno"
        >
            <option value="1">JYES</option>
            <option value="0">JNO</option>
        </field>
        <field
            name="telegram_notify_envio"
            type="radio"
            label="COM_ORDENPRODUCCION_CONFIG_TELEGRAM_NOTIFY_ENVIO_LABEL"
            description="COM_ORDENPRODUCCION_CONFIG_TELEGRAM_NOTIFY_ENVIO_DESC"
            default="0"
            class="btn-group btn-group-yesno"
        >
            <option value="1">JYES</option>
            <option value="0">JNO</option>
        </field>
        <field
            name="telegram_message_invoice"
            type="textarea"
            label="COM_ORDENPRODUCCION_CONFIG_TELEGRAM_MESSAGE_INVOICE_LABEL"
            description="COM_ORDENPRODUCCION_CONFIG_TELEGRAM_MESSAGE_INVOICE_DESC"
            rows="8"
            cols="80"
            filter="raw"
            default=""
        />
        <field
            name="telegram_message_envio"
            type="textarea"
            label="COM_ORDENPRODUCCION_CONFIG_TELEGRAM_MESSAGE_ENVIO_LABEL"
            description="COM_ORDENPRODUCCION_CONFIG_TELEGRAM_MESSAGE_ENVIO_DESC"
            rows="8"
            cols="80"
            filter="raw"
            default=""
        />
    </fieldset>
    <fieldset name="broadcast" label="COM_ORDENPRODUCCION_CONFIG_TELEGRAM_BROADCAST_FIELDSET_LABEL">
        <field
            name="telegram_broadcast_chat_id"
            type="text"
            label="COM_ORDENPRODUCCION_CONFIG_TELEGRAM_BROADCAST_CHAT_ID_LABEL"
            description="COM_ORDENPRODUCCION_CONFIG_TELEGRAM_BROADCAST_CHAT_ID_DESC"
            default=""
            size="50"
            filter="string"
        />
        <field
            name="telegram_broadcast_invoice"
            type="radio"
            label="COM_ORDENPRODUCCION_CONFIG_TELEGRAM_BROADCAST_EVENT_INVOICE_LABEL"
            description="COM_ORDENPRODUCCION_CONFIG_TELEGRAM_BROADCAST_EVENT_INVOICE_DESC"
            default="0"
            class="btn-group btn-group-yesno"
        >
            <option value="1">JYES</option>
            <option value="0">JNO</option>
        </field>
        <field
            name="telegram_broadcast_envio"
            type="radio"
            label="COM_ORDENPRODUCCION_CONFIG_TELEGRAM_BROADCAST_EVENT_ENVIO_LABEL"
            description="COM_ORDENPRODUCCION_CONFIG_TELEGRAM_BROADCAST_EVENT_ENVIO_DESC"
            default="0"
            class="btn-group btn-group-yesno"
        >
            <option value="1">JYES</option>
            <option value="0">JNO</option>
        </field>
        <field
            name="telegram_queue_cron_key"
            type="password"
            label="COM_ORDENPRODUCCION_CONFIG_TELEGRAM_QUEUE_CRON_KEY_LABEL"
            description="COM_ORDENPRODUCCION_CONFIG_TELEGRAM_QUEUE_CRON_KEY_DESC"
            default=""
            size="50"
            filter="string"
        />
    </fieldset>
</config>
